class Dog {
    fn init(name) {
        self.name = name
        self.tricks = []
    }
    fn learn(trick) {
        push(self.tricks, trick)
    }
    fn show() {
        print self.name + " knows: " + join(self.tricks, ", ")
    }
}
let buddy = Dog("Buddy")
buddy.learn("sit")
buddy.learn("shake")
buddy.show()
print isinstance(buddy, Dog)
