let payload = {
    "title": "Vion Scripting Language",
    "body": "Hello World",
    "userId": 1
}

let body = json_stringify(payload)
print "Body:", body

let options = {
    "method": "POST",
    "headers": {
        "Content-type": "application/json; charset=UTF-8"
    },
    "body": body
}

let response = http_request("https://jsonplaceholder.typicode.com/posts", options)
print "Response:", response
